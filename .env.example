# ==============================================================================
# UnLostPaws Vision Worker — environment template
# ==============================================================================
# Quick start:
#   cp .env.example .env
#   ./tools/run doctor              # detect hardware + recommend profile
#   docker compose up -d
#
# NVIDIA GPU production:
#   docker compose -f docker-compose.gpu.yml up -d
#   (VISION_PROFILE=gpu-standard is baked into that compose file)
# ==============================================================================

# ------------------------------------------------------------------------------
# Redis Stream Broker Configuration (Required)
# ------------------------------------------------------------------------------
# Redis connection endpoint. Use rediss:// for TLS (Upstash, managed Redis).
# Plain redis:// is only recommended when TLS is disabled (local dev).
REDIS_URL=redis://host.docker.internal:6379

# Fallback/Alternative Redis connection environment variable.
# If REDIS_URL is not set, the worker will attempt to load from UPSTASH_REDIS_URL.
# UPSTASH_REDIS_URL=rediss://default:your-token@your-host.upstash.io:6379

# Redis Stream key where incoming vision jobs are queued.
STREAM_KEY=unlostpaws:stream:vision-processing

# Dead Letter Queue stream key. Failed jobs are routed here after exceeding MAX_JOB_ATTEMPTS.
DLQ_STREAM_KEY=unlostpaws:stream:vision-processing:dlq

# Consumer group name registered on the Redis stream.
CONSUMER_GROUP=vision-worker

# Unique identifier for this worker instance within the consumer group.
CONSUMER_NAME=worker-1

# Maximum number of execution attempts before a job is written to the DLQ stream.
MAX_JOB_ATTEMPTS=3


# ------------------------------------------------------------------------------
# Model Pipeline & Execution Profiles
# ------------------------------------------------------------------------------
# The profile presets allocate resources based on the host system memory and GPU capacity.
# Pick ONE profile preset. See docs/INFERENCE_BACKENDS.md for full details.
#
# PyTorch Backend Profiles:
#   - dedup-only      : MD5 + pHash + quality checks — no ML models loaded (512MB RAM)
#   - cpu-light       : NSFW check on CPU, no matching embeddings (1.5GB RAM)
#   - cpu-standard    : SigLIP2 embeddings + NSFW check on CPU (3GB RAM)
#   - cpu-quality     : SigLIP2 embeddings + NSFW check + Pet Relevance on CPU (4GB RAM) [Default Dev]
#   - gpu-standard    : Full pipeline on GPU with torch.compile (4GB VRAM) [Default Prod]
#   - gpu-quality     : GPU + StrangerGuard multi-class NSFW with torch.compile (6GB VRAM)
#
# ONNX Runtime Backend Profiles:
#   - onnx-cpu-standard : ONNX INT8 SigLIP2 + Falconsai NSFW on CPU (2GB RAM)
#   - onnx-cpu-quality  : Full ONNX INT8 pipeline on CPU (3GB RAM)
#   - onnx-gpu-standard : ONNX FP16 full pipeline on NVIDIA GPU (4GB VRAM)
#   - onnx-gpu-quality  : ONNX FP16 GPU + StrangerGuard safety (6GB VRAM)
#   - onnx-trt-standard : ONNX TensorRT EP — max NVIDIA throughput (6GB VRAM)
#   - onnx-trt-quality  : ONNX TensorRT EP + StrangerGuard safety (8GB VRAM)
#   - onnx-intel        : ONNX OpenVINO EP — Intel CPU/iGPU/NPU (3GB RAM)
#   - onnx-apple        : ONNX CoreML EP — Apple Neural Engine (3GB RAM)
#   - onnx-qualcomm     : ONNX QNN EP — Qualcomm Hexagon NPU (3GB RAM)
#
VISION_PROFILE=cpu-quality

# Force hardware execution device. 
# Options: 'cpu', 'cuda', or 'auto' (resolves automatically based on profile).
DEVICE=auto

# Batch size for processing images concurrently in GPU stage loaders.
# Defaults are configured per profile (e.g. 1 on CPU, 4-8 on GPU).
# BATCH_SIZE=1


# ------------------------------------------------------------------------------
# Network and Timeout Settings
# ------------------------------------------------------------------------------
# HTTP timeout in seconds for downloading images from the job payload.
DOWNLOAD_TIMEOUT=30

# Maximum number of concurrent HTTP image downloads to execute at one time.
MAX_CONCURRENT_DOWNLOADS=4

# HTTP timeout in seconds when posting processing results back to the callback webhook.
CALLBACK_TIMEOUT=60


# ------------------------------------------------------------------------------
# Model Registry & Hugging Face Cache
# ------------------------------------------------------------------------------
# Environment flag to let the application know it's running inside Docker.
# This is automatically set to 'true' inside the Docker image (via Dockerfile).
# Leave this commented out so it doesn't accidentally override the container environment.
# RUNNING_IN_DOCKER=true

# Hugging Face local cache directory where models and tokenizers are stored.
# Auto-detects ~/.cache/huggingface locally and /app/.cache/huggingface in Docker.
# HF_HOME=~/.cache/huggingface

# Custom model cache directory for ONNX models.
# Defaults to $HF_HOME/onnx.
# MODEL_CACHE_DIR=~/.cache/huggingface/onnx

# Custom TensorRT engine cache directory (used for TensorRT profiles).
# Defaults to $HF_HOME/tensorrt.
# TENSORRT_CACHE_DIR=~/.cache/huggingface/tensorrt


# ==============================================================================
# ADVANCED OVERRIDES & MAINTENANCE KNOBS
# ==============================================================================
# The parameters below are automatically configured by the selected VISION_PROFILE.
# Un-comment and modify these ONLY if you need to override profile defaults.

# --- Custom Model Overrides ---
# Override the Hugging Face repository IDs or local paths for model weights.
# MATCH_MODEL=google/siglip2-base-patch16-224
# SAFETY_MODEL=Falconsai/nsfw_image_detection

# --- Inference Engine Overrides ---
# Choose the backend framework. Options: 'torch', 'onnx'.
# INFERENCE_RUNTIME=onnx

# Specify the ONNX Runtime execution provider.
# Options: 'cpu', 'cuda', 'tensorrt', 'openvino', 'coreml', 'qnn'.
# ORT_EXECUTION_PROVIDER=cpu

# Choose the model precision. Options: 'fp32', 'fp16', 'int8'.
# MODEL_PRECISION=int8

# Enable or disable PyTorch compile optimization (requires PyTorch 2.x).
# TORCH_COMPILE=false

# --- Container Metadata ---
# Used for hardware preflight check and variant validation.
# Options: 'cpu', 'gpu', or 'unknown'.
# WORKER_IMAGE_VARIANT=unknown

# --- Historical / Inactive Settings ---
# Note: The codebase currently configures stages based strictly on the selected
# VISION_PROFILE (e.g., embedding vector generation is enabled only in profiles 
# that include "embed" in their stages). The variables below are ignored by the 
# Python application load_settings() method, but are kept for documentation/reference.
# EMBED_ENABLED=true
# SAFETY_ENABLED=true
# RELEVANCE_ENABLED=true

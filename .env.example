# ==============================================================================
# UnLostPaws Vision Worker — environment template
# ==============================================================================
# Quick start:
#   cp .env.example .env
#   ./tools/run doctor              # detect hardware + recommend profile
#   docker compose up -d
#
# NVIDIA GPU production:
#   docker compose -f docker-compose.gpu.yml up -d
#   (VISION_PROFILE=gpu-standard is baked into that compose file)
# ==============================================================================

# --- Redis (required) ---
# Use rediss:// for TLS (Upstash, managed Redis). Plain redis:// only when TLS is off.
REDIS_URL=redis://host.docker.internal:6379
STREAM_KEY=unlostpaws:stream:vision-processing
DLQ_STREAM_KEY=unlostpaws:stream:vision-processing:dlq
CONSUMER_GROUP=vision-worker
CONSUMER_NAME=worker-1
MAX_JOB_ATTEMPTS=3

# --- Vision profile (pick ONE — see docs/GUIDE.md for tiers) ---
#
# Dev laptop / x86 Linux CPU (default):
VISION_PROFILE=cpu-quality
#
# ARM64 SBC / Graviton (smaller ONNX footprint):
# VISION_PROFILE=onnx-cpu-quality
#
# Intel CPU / iGPU / NPU (requires onnxruntime-openvino in image or pip):
# VISION_PROFILE=onnx-intel
#
# Apple Silicon — run Python natively on macOS, NOT in Linux Docker:
# VISION_PROFILE=onnx-apple
#
# Qualcomm NPU — Windows ARM64 + onnxruntime-qnn:
# VISION_PROFILE=onnx-qualcomm
#
# NVIDIA GPU — use docker-compose.gpu.yml (profile baked in).

# Optional: force device (usually leave auto; GPU compose sets cuda).
DEVICE=auto
# BATCH_SIZE=1

# Pipeline stages are controlled by VISION_PROFILE only (no per-stage env toggles).

# --- Model cache ---
# Auto-detects ~/.cache/huggingface locally and /app/.cache/huggingface in Docker.
# HF_HOME=~/.cache/huggingface

# --- Network ---
DOWNLOAD_TIMEOUT=30
MAX_CONCURRENT_DOWNLOADS=4
CALLBACK_TIMEOUT=60
RUNNING_IN_DOCKER=false

# Advanced inference overrides (rarely needed — profile sets these):
# INFERENCE_RUNTIME=onnx
# ORT_EXECUTION_PROVIDER=cpu
# MODEL_PRECISION=int8
# TORCH_COMPILE=false

# ==============================================================================
# UnLostPaws Vision Worker Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' at the project root and adjust for your environment.
# E.g., cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Redis Stream Broker Configuration
# ------------------------------------------------------------------------------
# Shared Redis instance URI. Used to poll jobs via consumer groups and XREADGROUP.
# Supports redis:// (unencrypted) and rediss:// (SSL/TLS). 
# Can also be set via UPSTASH_REDIS_URL.
REDIS_URL=redis://host.docker.internal:6379

# Redis Stream key where incoming vision jobs are queued.
STREAM_KEY=unlostpaws:stream:vision-processing

# Dead Letter Queue stream key. Failed jobs are routed here after exceeding MAX_JOB_ATTEMPTS.
DLQ_STREAM_KEY=unlostpaws:stream:vision-processing:dlq

# Consumer group name registered on the Redis stream.
CONSUMER_GROUP=vision-worker

# Unique identifier for this worker instance within the consumer group.
CONSUMER_NAME=worker-1

# Maximum number of execution attempts before a job is written to the DLQ stream.
MAX_JOB_ATTEMPTS=3


# ------------------------------------------------------------------------------
# Model Pipeline & Execution Profiles
# ------------------------------------------------------------------------------
# The profile presets allocate resources based on the host system memory and GPU capacity:
#   - dedup-only   : No Torch loaded. Performs quality checks, MD5 & pHash.
#   - cpu-light    : Modest CPU footprint. NSFW check only, no matching embeddings.
#   - cpu-standard : SigLIP2 embeddings + Falconsai NSFW check on CPU.
#   - cpu-quality  : SigLIP2 embeddings + Falconsai NSFW check + Pet Relevance on CPU (Default Dev).
#   - gpu-standard : SigLIP2 embeddings + Falconsai NSFW check + Pet Relevance on GPU (Default Prod).
#   - gpu-quality  : SigLIP2 embeddings + StrangerGuard multi-class NSFW + Pet Relevance on GPU.
VISION_PROFILE=cpu-quality

# Force hardware execution device. 
# Options: 'cpu', 'cuda', or 'auto' (resolves automatically based on profile).
DEVICE=auto

# Batch size for processing images concurrently in GPU stage loaders.
# Defaults are configured per profile (e.g. 1 on CPU, 4-8 on GPU).
BATCH_SIZE=1


# ------------------------------------------------------------------------------
# Stage Feature Flags (Overrides Preset Settings)
# ------------------------------------------------------------------------------
# Enable or disable the embedding vector generation stage.
EMBED_ENABLED=true

# Enable or disable content moderation and NSFW filter stage.
SAFETY_ENABLED=true

# Enable or disable pet verification zero-shot classification stage.
RELEVANCE_ENABLED=true


# ------------------------------------------------------------------------------
# Model Registry & Hugging Face Cache
# ------------------------------------------------------------------------------
# Custom overrides for default models. Leave commented out to use preset defaults.
# MATCH_MODEL=google/siglip2-base-patch16-224
# SAFETY_MODEL=Falconsai/nsfw_image_detection

# Hugging Face local cache directory where models and tokenizers are stored.
HF_HOME=/app/.cache/huggingface


# ------------------------------------------------------------------------------
# Network and Timeout Settings
# ------------------------------------------------------------------------------
# HTTP timeout in seconds for downloading images from the job payload.
DOWNLOAD_TIMEOUT=30

# Maximum number of concurrent HTTP image downloads to execute at one time.
MAX_CONCURRENT_DOWNLOADS=4

# HTTP timeout in seconds when posting processing results back to Next.js callback webhook.
CALLBACK_TIMEOUT=60

# Set to true when running inside Docker container to enable localhost URL rewriting to host.docker.internal
RUNNING_IN_DOCKER=false

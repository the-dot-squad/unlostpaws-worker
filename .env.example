# ==============================================================================
# UnLostPaws Vision Worker — environment template
# ==============================================================================
# Quick start:
#   cp .env.example .env
#   ./tools/run doctor
#   docker compose up -d
# ==============================================================================

# ------------------------------------------------------------------------------
# Redis (required)
# ------------------------------------------------------------------------------
REDIS_URL=redis://host.docker.internal:6379
STREAM_KEY=unlostpaws:stream:vision-processing
DLQ_STREAM_KEY=unlostpaws:stream:vision-processing:dlq
CONSUMER_GROUP=vision-worker
CONSUMER_NAME=worker-1
MAX_JOB_ATTEMPTS=3

# ------------------------------------------------------------------------------
# Profile — what pipeline runs and which SigLIP checkpoint is used
# Hardware is configured separately below.
#
#   dedup-only  — MD5 + pHash + quality only (no ML)
#   standard    — SigLIP2 base @ 224px + relevance + NSFW (768-d, fast indexing)
#   quality     — SigLIP2 base @ 384px + relevance + NSFW (768-d, default prod)
#
VISION_PROFILE=quality

# ------------------------------------------------------------------------------
# Runtime and hardware
# ------------------------------------------------------------------------------
# torch = PyTorch (default). onnx = ONNX Runtime.
INFERENCE_RUNTIME=torch

# Torch: cpu or cuda (cuda with docker-compose.gpu.yml).
DEVICE=auto

# ONNX only: cpu, cuda, tensorrt, coreml, openvino, qnn
# ORT_EXECUTION_PROVIDER=cpu

# ------------------------------------------------------------------------------
# Optional overrides (defaults come from VISION_PROFILE)
# ------------------------------------------------------------------------------
# MATCH_MODEL=google/siglip2-base-patch16-224
# SAFETY_MODEL=Falconsai/nsfw_image_detection
# SAFETY_MODEL=strangerguardhf/nsfw-image-detection
# MODEL_PRECISION=fp32|fp16|int8
# BATCH_SIZE=1
# TORCH_COMPILE=false
# OPENVINO_DEVICE=NPU

# ------------------------------------------------------------------------------
# Network and cache
# ------------------------------------------------------------------------------
DOWNLOAD_TIMEOUT=30
MAX_CONCURRENT_DOWNLOADS=4
CALLBACK_TIMEOUT=60
# HF_HOME=~/.cache/huggingface

# Docker fail-fast metadata (set by compose / Dockerfile):
# WORKER_IMAGE_VARIANT=cpu
# RUNNING_IN_DOCKER=true
